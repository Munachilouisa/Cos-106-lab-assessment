# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ── Build outputs ────────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Expo ─────────────────────────────────────────────────────────────────────
.expo/
.expo-shared/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Database ─────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
drizzle/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-error.log
pnpm-debug.log*
testem.log

# ── Coverage ─────────────────────────────────────────────────────────────────
/coverage/

# ── IDEs & editors ───────────────────────────────────────────────────────────
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc ──────────────────────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/libpeerconnection.log
/typings

# ── Cursor / GitHub Copilot generated files ──────────────────────────────────
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ── Replit-managed (do not commit) ───────────────────────────────────────────
.cache/
.local/
.agents/
